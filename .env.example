# ============================================================
#  ZAR ULTIMATE BOT v6 — Variables de Entorno
#  Copia este archivo a .env y rellena con tus credenciales.
#  NUNCA subas el archivo .env al repositorio.
# ============================================================

# ── MetaTrader 5 ─────────────────────────────────────────────
MT5_LOGIN=TU_NUMERO_DE_CUENTA
MT5_PASSWORD=TU_CONTRASENA
MT5_SERVER=ICMarketsSC-MT5-2
# Para IC Markets SC Live usa: ICMarketsSC-MT5-2  (servidor de cuentas reales)
# Para IC Markets SC Demo usa: ICMarketsSC-Demo    (servidor de cuentas demo)
# Para Exness Demo usa:        Exness-MT5Trial11
# MT5_SERVER=Exness-MT5Trial11

# ── Sufijo de símbolo del broker ──────────────────────────────
# Exness:     BROKER_SUFFIX=m  (XAUUSDm, EURUSDm…)
# IC Markets: BROKER_SUFFIX=    (XAUUSD, EURUSD… — dejar en blanco)
BROKER_SUFFIX=

# ── Groq ───────────────────────────────────────────────────────
GROQ_API_KEY=TU_API_KEY_GROQ
# GROQ_API_KEY_2=TU_API_KEY_GROQ_2
# GROQ_API_KEY_3=TU_API_KEY_GROQ_3
# GROQ_API_KEY_4=TU_API_KEY_GROQ_4
# GROQ_MODEL=llama-3.3-70b-versatile   # opcional, este es el default
# GROQ_API_KEYS=TU_KEY_PROYECTO_A,TU_KEY_PROYECTO_B
# Si usas varias llaves, usa proyectos distintos. Varias llaves del mismo
# proyecto/organización no multiplican la cuota total.
# GROQ_MAX_CALLS_PER_HOUR y GROQ_MAX_CALLS_PER_DAY se interpretan por key.
# GROQ_SYMBOL_COOLDOWN_SEC=300
# GROQ_MIN_ENTRY_QUALITY=2
# GROQ_ENTRY_STRONG_ONLY=1
# GROQ_ENTRY_CONF_MULT=1.8
# GROQ_CLIENT_MAX_RETRIES=0
# ENTRY_MIN_RR=1.20
# SCALPING_ALLOW_LOW_HURST=1
# SCALPING_HURST_HARD_FLOOR=0.18
# SCALPING_HURST_SOFT_MARGIN=0.20
# SCALPING_TP_MULT=0.82
# SCALPING_BE_PIPS_STAGE_1=7.0
# SCALPING_BE_PIPS_STAGE_2=12.0
# SCALPING_BE_PIPS_STAGE_3=18.0
# SCALPING_BE_PIPS_STAGE_4=25.0
# CLOSURE_HISTORY_LOOKBACK_DAYS=30
# MAX_OPEN_PER_SYMBOL=3

# ── Telegram ──────────────────────────────────────────────────
# MEMORY_BLOCK_NOTIFY_COOLDOWN_SEC=14400   # 4h entre avisos repetidos del mismo bloqueo
TELEGRAM_TOKEN=TU_BOT_TOKEN_TELEGRAM
TELEGRAM_CHAT_ID=TU_CHAT_ID_TELEGRAM

# ── APIs Externas (opcionales) ────────────────────────────────
# Si no las configuras el bot arranca igual; solo se usan si están presentes.
ALPHA_VANTAGE_KEY=TU_API_KEY_ALPHA_VANTAGE
FINNHUB_KEY=TU_API_KEY_FINNHUB

# ── Data Providers (opcionales) ───────────────────────────────
TWELVE_DATA_KEY=TU_API_KEY_TWELVE_DATA
POLYGON_KEY=TU_API_KEY_POLYGON

# ── Gestión de Riesgo (opcionales — los defaults son seguros) ─
# Circuit Breaker: cierre forzado si el drawdown de una posición
# supera este % del balance (0.0 = desactivado).
CIRCUIT_BREAKER_MAX_DRAWDOWN_PCT=3.0
# Modo Calentamiento: trades necesarios para salir del warmup y activar MLP.
# FIX v6.6: Reducido a 50. Con 100 el bot bloqueaba demasiado en símbolos de rango.
# WARMUP_TRADE_COUNT=50
# Multiplicador de lote durante el warmup (0.5 = mitad del lote).
# WARMUP_LOT_FACTOR=0.5
