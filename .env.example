# ============================================================
#  ZAR ULTIMATE BOT v7 — Variables de Entorno (SCALPING PURO)
#  Copia este archivo a .env y rellena con tus credenciales.
#  NUNCA subas el archivo .env al repositorio.
#
#  v7.0: Bot configurado para SCALPING PURO con 5 símbolos.
#  Objetivo: $5+ USD por operación con R:R ≥ 1.50 simétrico.
# ============================================================

# ── MetaTrader 5 ─────────────────────────────────────────────
MT5_LOGIN=TU_NUMERO_DE_CUENTA
MT5_PASSWORD=TU_CONTRASENA
MT5_SERVER=ICMarketsSC-MT5-2
# Para IC Markets SC Live usa: ICMarketsSC-MT5-2  (servidor de cuentas reales)
# Para IC Markets SC Demo usa: ICMarketsSC-Demo    (servidor de cuentas demo)
# Para Exness Demo usa:        Exness-MT5Trial11
# MT5_SERVER=Exness-MT5Trial11

# ── Sufijo de símbolo del broker ──────────────────────────────
# Exness:     BROKER_SUFFIX=m  (XAUUSDm, EURUSDm…)
# IC Markets: BROKER_SUFFIX=    (XAUUSD, EURUSD… — dejar en blanco)
BROKER_SUFFIX=

# ── Groq ───────────────────────────────────────────────────────
GROQ_API_KEY=TU_API_KEY_GROQ
# GROQ_API_KEY_2=TU_API_KEY_GROQ_2
# GROQ_API_KEY_3=TU_API_KEY_GROQ_3
# GROQ_MODEL=llama-3.3-70b-versatile   # opcional, este es el default

# ── Parámetros de scalping (v7.0 defaults — ya optimizados) ───
# GROQ_SYMBOL_COOLDOWN_SEC=300      # 5 min entre llamadas Groq por símbolo
# GROQ_MIN_ENTRY_QUALITY=2          # v7.0: 3→2 (menos restrictivo para scalping)
# GROQ_ENTRY_STRONG_ONLY=1
# ENTRY_MIN_RR=1.50                 # v7.0: 1.20→1.50 (R:R mínimo más estricto)
# SCALPING_ONLY=1
# SCALPING_TP_MULT=0.98             # v7.0: 0.82→0.98 (no destruye R:R en SELL)
# SCALPING_BE_MIN_PIPS=5.0          # v7.0: 2.0→5.0 (no activar trail en ruido)
# SCALPING_BE_PIPS_STAGE_1=5.0
# SCALPING_BE_PIPS_STAGE_2=8.0
# SCALPING_BE_PIPS_STAGE_3=12.0
# SCALPING_BE_PIPS_STAGE_4=18.0
# MIN_EXPECTED_PROFIT_USD=5.0       # v7.0 NUEVO: bloquea si profit esperado < $5
# MAX_OPEN_PER_SYMBOL=1             # v7.0: 3→1 (un trade por símbolo a la vez)

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_TOKEN=TU_BOT_TOKEN_TELEGRAM
TELEGRAM_CHAT_ID=TU_CHAT_ID_TELEGRAM

# ── APIs Externas (opcionales) ────────────────────────────────
ALPHA_VANTAGE_KEY=TU_API_KEY_ALPHA_VANTAGE
FINNHUB_KEY=TU_API_KEY_FINNHUB
TWELVE_DATA_KEY=TU_API_KEY_TWELVE_DATA
POLYGON_KEY=TU_API_KEY_POLYGON

# ── Gestión de Riesgo ─────────────────────────────────────────
CIRCUIT_BREAKER_MAX_DRAWDOWN_PCT=3.0
# WARMUP_TRADE_COUNT=50
# WARMUP_LOT_FACTOR=0.5
